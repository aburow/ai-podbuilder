# kaos-control SQLite index (generated; do not commit)
kaos/
lifecycle/.kaos-control.db
lifecycle/.kaos-control.db-shm
lifecycle/.kaos-control.db-wal

# Local kaos-control pipeline definitions — operational, not for remote
lifecycle/devops/*.yaml

# Runtime project data — never commit user projects or live secrets
projects/
*.env
!*.env.example
!config/agents.d/*.env

# SSH keys and TLS material
.ssh/
*.pem
*.key
id_rsa
id_ed25519
id_ecdsa
known_hosts

# Local shell history
.bash_history

# OS artefacts
.DS_Store
Thumbs.db

# Editor directories and files
.idea/
.vscode/
.cl[a]ude/
.codex/
*.swp
*.swo
