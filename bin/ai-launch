#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/common.sh
source "${SCRIPT_DIR}/../lib/common.sh"
# shellcheck source=../lib/profile.sh
source "${SCRIPT_DIR}/../lib/profile.sh"
# shellcheck source=../lib/policy.sh
source "${SCRIPT_DIR}/../lib/policy.sh"
# shellcheck source=../lib/container.sh
source "${SCRIPT_DIR}/../lib/container.sh"
# shellcheck source=../lib/frontend.sh
source "${SCRIPT_DIR}/../lib/frontend.sh"
# shellcheck source=../lib/usage.sh
source "${SCRIPT_DIR}/../lib/usage.sh"

# Mode → in-container command table (extensible without touching safety core).
declare -A MODE_CMDS
MODE_CMDS=(
    [shell]="bash"
    [bash]="bash"
    [codex]="codex"
    [codex]="codex"
    [aider]="aider"
    [opencode]="opencode"
    [ollama-shell]="ollama run"
)

resolve_base_dir
require_cmd podman

# ── Argument parsing ─────────────────────────────────────────────────────────
PROFILE_ARG=""
_LAUNCH_MODE="shell"
FLAG_YES=0
FLAG_NON_INTERACTIVE=0
FLAG_RECREATE=0
FLAG_NO_RECREATE=0
FLAG_RESET=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)          usage_ai_launch; exit 0 ;;
        --yes)              FLAG_YES=1; shift ;;
        --non-interactive)  FLAG_NON_INTERACTIVE=1; shift ;;
        --recreate)         FLAG_RECREATE=1; shift ;;
        --no-recreate)      FLAG_NO_RECREATE=1; shift ;;
        --reset)            FLAG_RESET=1; shift ;;
        -*)                 usage_ai_launch; exit 1 ;;
        *)
            if [[ -z "$PROFILE_ARG" ]]; then
                PROFILE_ARG="$1"
            elif [[ "$_LAUNCH_MODE" == "shell" ]]; then
                _LAUNCH_MODE="$1"
            else
                usage_ai_launch; exit 1
            fi
            shift
            ;;
    esac
done

[[ -n "$PROFILE_ARG" ]] || { usage_ai_launch; exit 0; }

load_profile "$PROFILE_ARG"

# Validate mode.
if [[ "$_LAUNCH_MODE" != "builder" ]]; then
    [[ -v MODE_CMDS["$_LAUNCH_MODE"] ]] \
        || _die "Unknown mode: '${_LAUNCH_MODE}'. Valid modes: ${!MODE_CMDS[*]}, builder"
fi

# ── DRY_RUN testability mode (prints assembled args without executing) ────────
if [[ "${DRY_RUN:-0}" == "1" ]]; then
    if [[ "$_LAUNCH_MODE" == "builder" ]]; then
        build_builder_run_args
        printf 'DRY_RUN:run\n'
        printf '%s\n' "${_BUILDER_RUN_ARGS[@]}" "$IMAGE_NAME" bash
    else
        build_normal_run_args
        printf 'DRY_RUN:create\n'
        printf -- '--name\n%s\n' "$CONTAINER_NAME"
        printf '%s\n' "${_NORMAL_RUN_ARGS[@]}" "$IMAGE_NAME"
    fi
    exit 0
fi

# ── Path bootstrap (R4.1) ─────────────────────────────────────────────────────
mkdir -p "$WORKSPACE" "$CONTAINER_HOME"
[[ -z "${PNPM_HOME:-}" ]] || mkdir -p "$PNPM_HOME"
HISTFILE="${HISTFILE:-${WORKSPACE}/.bash_history}"
touch "$HISTFILE"

# ── Builder mode (R4.5, R4.12) — ephemeral privileged container ──────────────
if [[ "$_LAUNCH_MODE" == "builder" ]]; then
    render_launch_summary "no"
    run_builder_ephemeral bash --rcfile "$BASHRC_CONTAINER" -i
    exit 0
fi

# ── Reset (B7: --reset) ───────────────────────────────────────────────────────
if [[ "$FLAG_RESET" -eq 1 ]]; then
    _reset_yes=0
    if [[ "$FLAG_YES" -eq 1 || "$FLAG_NON_INTERACTIVE" -eq 1 ]]; then
        _reset_yes=1
    elif is_interactive && container_running "$CONTAINER_NAME"; then
        confirm_reset && _reset_yes=1
    fi
    reset_container "$( [[ "$_reset_yes" -eq 1 ]] && echo "yes" || echo "no" )"
    exit 0
fi

# ── Persistent container: create or reuse; staleness check (R4.2, R4.9) ──────
REUSING="no"
if container_exists "$CONTAINER_NAME"; then
    REUSING="yes"
    if [[ "$FLAG_RECREATE" -eq 1 ]]; then
        recreate_preserving_workspace
        create_normal_container
        REUSING="no"
    elif image_is_stale; then
        if [[ "$FLAG_NO_RECREATE" -eq 1 || "$FLAG_YES" -eq 1 || "$FLAG_NON_INTERACTIVE" -eq 1 ]]; then
            _warn "Image has changed; continuing with existing container '${CONTAINER_NAME}' (use --recreate to update)."
        elif is_interactive; then
            stale_choice="$(prompt_stale_choice)"
            case "$stale_choice" in
                recreate)
                    recreate_preserving_workspace
                    create_normal_container
                    REUSING="no"
                    ;;
                cancel)
                    _info "Cancelled. Use --recreate to update or --no-recreate to keep the existing container."
                    exit 0
                    ;;
                continue|*)
                    _info "Continuing with existing container '${CONTAINER_NAME}'."
                    ;;
            esac
        else
            warn_stale_noninteractive
        fi
    fi
else
    create_normal_container
fi

# ── Pre-launch summary (R4.8) ─────────────────────────────────────────────────
render_launch_summary "$REUSING"

# ── Attach or exec mode command ───────────────────────────────────────────────
if [[ "$_LAUNCH_MODE" == "shell" || "$_LAUNCH_MODE" == "bash" ]]; then
    start_and_attach
else
    if ! container_running "$CONTAINER_NAME"; then
        podman start "$CONTAINER_NAME"
    fi
    exec_mode_command "$CONTAINER_NAME" "${MODE_CMDS[$_LAUNCH_MODE]}"
fi
