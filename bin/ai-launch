#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/common.sh
source "${SCRIPT_DIR}/../lib/common.sh"
# shellcheck source=../lib/profile.sh
source "${SCRIPT_DIR}/../lib/profile.sh"
# shellcheck source=../lib/policy.sh
source "${SCRIPT_DIR}/../lib/policy.sh"
# shellcheck source=../lib/container.sh
source "${SCRIPT_DIR}/../lib/container.sh"
# shellcheck source=../lib/frontend.sh
source "${SCRIPT_DIR}/../lib/frontend.sh"

usage() {
    cat >&2 <<'EOF'
Usage: ai-launch <profile> [mode] [flags]

Launch a persistent sandbox container for the named profile. If a container
named by the profile already exists, it is reused; otherwise created.

Modes (default: shell):
  shell / bash   Interactive bash shell (default)
  codex          Run the Codex agent
  codex         Run the Codex agent
  builder        Privileged ephemeral build container (the only --privileged path)
  aider          Run the Aider agent
  opencode       Run the OpenCode agent
  ollama-shell   Run an Ollama interactive shell

Flags:
  --yes / --non-interactive   Non-interactive: warn and continue on staleness
  --recreate                  Remove and recreate the persistent container from
                              the current image (workspace preserved)
  --no-recreate               Explicitly continue with the existing container
  -h, --help                  Show this help and exit.
EOF
}

# Mode → in-container command table (extensible without touching safety core).
declare -A MODE_CMDS
MODE_CMDS=(
    [shell]="bash"
    [bash]="bash"
    [codex]="codex"
    [codex]="codex"
    [aider]="aider"
    [opencode]="opencode"
    [ollama-shell]="ollama run"
)

resolve_base_dir
require_cmd podman

# ── Argument parsing ─────────────────────────────────────────────────────────
PROFILE_ARG=""
_LAUNCH_MODE="shell"
FLAG_YES=0
FLAG_NON_INTERACTIVE=0
FLAG_RECREATE=0
FLAG_NO_RECREATE=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)          usage; exit 0 ;;
        --yes)              FLAG_YES=1; shift ;;
        --non-interactive)  FLAG_NON_INTERACTIVE=1; shift ;;
        --recreate)         FLAG_RECREATE=1; shift ;;
        --no-recreate)      FLAG_NO_RECREATE=1; shift ;;
        -*)                 _die "Unknown flag: $1. Run 'ai-launch --help' for usage." ;;
        *)
            if [[ -z "$PROFILE_ARG" ]]; then
                PROFILE_ARG="$1"
            elif [[ "$_LAUNCH_MODE" == "shell" ]]; then
                _LAUNCH_MODE="$1"
            else
                _die "Unexpected argument: $1"
            fi
            shift
            ;;
    esac
done

[[ -n "$PROFILE_ARG" ]] || { usage; exit 0; }

load_profile "$PROFILE_ARG"

# Validate mode.
if [[ "$_LAUNCH_MODE" != "builder" ]]; then
    [[ -v MODE_CMDS["$_LAUNCH_MODE"] ]] \
        || _die "Unknown mode: '${_LAUNCH_MODE}'. Valid modes: ${!MODE_CMDS[*]}, builder"
fi

# ── Path bootstrap (R4.1) ─────────────────────────────────────────────────────
mkdir -p "$WORKSPACE" "$CONTAINER_HOME"
[[ -z "${PNPM_HOME:-}" ]] || mkdir -p "$PNPM_HOME"
HISTFILE="${HISTFILE:-${WORKSPACE}/.bash_history}"
touch "$HISTFILE"

# ── Builder mode (R4.5, R4.12) — ephemeral privileged container ──────────────
if [[ "$_LAUNCH_MODE" == "builder" ]]; then
    render_launch_summary "no"
    run_builder_ephemeral bash
    exit 0
fi

# ── Persistent container: create or reuse; staleness check (R4.2, R4.9) ──────
REUSING="no"
if container_exists "$CONTAINER_NAME"; then
    REUSING="yes"
    if image_is_stale; then
        if [[ "$FLAG_RECREATE" -eq 1 ]]; then
            recreate_preserving_workspace
            create_normal_container
            REUSING="no"
        elif [[ "$FLAG_NO_RECREATE" -eq 1 || "$FLAG_YES" -eq 1 || "$FLAG_NON_INTERACTIVE" -eq 1 ]]; then
            _warn "Image has changed; continuing with existing container '${CONTAINER_NAME}' (use --recreate to update)."
        elif is_interactive; then
            stale_choice="$(prompt_stale_choice)"
            case "$stale_choice" in
                recreate)
                    recreate_preserving_workspace
                    create_normal_container
                    REUSING="no"
                    ;;
                cancel)
                    _info "Cancelled. Use --recreate to update or --no-recreate to keep the existing container."
                    exit 0
                    ;;
                continue|*)
                    _info "Continuing with existing container '${CONTAINER_NAME}'."
                    ;;
            esac
        else
            _warn "Image has changed; non-interactive — continuing with existing container '${CONTAINER_NAME}'."
        fi
    fi
else
    create_normal_container
fi

# ── Pre-launch summary (R4.8) ─────────────────────────────────────────────────
render_launch_summary "$REUSING"

# ── Attach or exec mode command ───────────────────────────────────────────────
if [[ "$_LAUNCH_MODE" == "shell" || "$_LAUNCH_MODE" == "bash" ]]; then
    start_and_attach
else
    if ! container_running "$CONTAINER_NAME"; then
        podman start "$CONTAINER_NAME"
    fi
    exec_mode_command "$CONTAINER_NAME" "${MODE_CMDS[$_LAUNCH_MODE]}"
fi
