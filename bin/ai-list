#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/common.sh
source "${SCRIPT_DIR}/../lib/common.sh"
source "${SCRIPT_DIR}/../lib/slug.sh"
# shellcheck source=../lib/container.sh
source "${SCRIPT_DIR}/../lib/container.sh"
# shellcheck source=../lib/usage.sh
source "${SCRIPT_DIR}/../lib/usage.sh"
# shellcheck source=../lib/render.sh
source "${SCRIPT_DIR}/../lib/render.sh"

case "${1:-}" in
    -h|--help) usage_ai_list; exit 0 ;;
    -*) usage_ai_list; exit 1 ;;
esac

resolve_base_dir
require_cmd podman

# Build a de-duplicated list of profile files, keyed by slug.
# Project-tree entries take precedence; legacy profiles/ entries fill gaps.
declare -A seen_slugs   # slug → 1
profile_files=()

shopt -s nullglob
for project_profile in "${CODEX_JAILS_DIR}"/projects/*/profile.env; do
    project_name="$(basename "$(dirname "$project_profile")")"
    slug="$(sanitize_slug "$project_name")"
    if [[ -z "${seen_slugs[$slug]+x}" ]]; then
        seen_slugs[$slug]=1
        profile_files+=("$project_profile")
    fi
done

PDIR="$(profiles_dir)"
if [[ -d "$PDIR" ]]; then
    for legacy_profile in "${PDIR}"/*.env; do
        slug="$(basename "$legacy_profile" .env)"
        if [[ -z "${seen_slugs[$slug]+x}" ]]; then
            seen_slugs[$slug]=1
            profile_files+=("$legacy_profile")
        fi
    done
fi
shopt -u nullglob

if [[ ${#profile_files[@]} -eq 0 ]]; then
    _info "No profiles found (looked in projects/ and profiles/)"
    exit 0
fi

# Gather tab-delimited rows: name\timage\tworkspace\tstate
rows=()
for pfile in "${profile_files[@]}"; do
    row="$(
        # shellcheck source=/dev/null
        source "$pfile"
        state="absent"
        if podman container exists "${CONTAINER_NAME}" 2>/dev/null; then
            status="$(podman inspect --format '{{.State.Status}}' "${CONTAINER_NAME}" 2>/dev/null)"
            state="${status:-unknown}"
        fi
        printf '%s\t%s\t%s\t%s' "${PROFILE_NAME}" "${IMAGE_NAME}" "${WORKSPACE}" "${state}"
    )"
    rows+=("$row")
done

render_profile_table "${rows[@]}"
