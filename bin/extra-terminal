set -euo pipefail
# Legacy wrapper: attaches an extra terminal to the profile given as $1,
# defaulting to esp32 for backwards compatibility.
exec "$(dirname "${BASH_SOURCE[0]}")/ai-terminal" "${1:-esp32}"
