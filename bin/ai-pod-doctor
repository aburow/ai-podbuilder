#!/usr/bin/env bash
# SPDX-License-Identifier: GPL-3.0-only
# 2026 - Anthony Burow - https://github.com/aburow
set -euo pipefail
trap 'exit 4' ERR

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/common.sh
source "${SCRIPT_DIR}/../lib/common.sh"
# shellcheck source=../lib/integrity.sh
source "${SCRIPT_DIR}/../lib/integrity.sh"

resolve_base_dir

_usage() {
    cat >&2 <<'EOF'
Usage: ai-pod-doctor [integrity-check] [OPTIONS]

Verify installed system files against the release tarball.

Options:
  --verbose   Show all files (OK and exceptions)
  --diff      Show unified diffs for modified files
  --repair    Restore missing/modified files without prompting
  -h, --help  Show this help

Exit codes:
  0  All files match (or repair succeeded)
  1  Discrepancies found (or repair declined)
  2  Tarball fetch failure
  3  Version detection failure
  4  Unexpected error
EOF
    exit 0
}

# ---- argument parsing -------------------------------------------------------

OPT_VERBOSE=0
OPT_DIFF=0
SUBCMD=""

for arg in "$@"; do
    case "${arg}" in
        integrity-check) SUBCMD="integrity-check" ;;
        --verbose)       OPT_VERBOSE=1 ;;
        --diff)          OPT_DIFF=1 ;;
        -h|--help)       _usage ;;
        *) echo "Unknown option: ${arg}" >&2; exit 1 ;;
    esac
done

[[ -z "${SUBCMD}" ]] && SUBCMD="integrity-check"

# ---- integrity-check flow --------------------------------------------------

_ic_setup_tmpdir
detect_version
fetch_tarball
build_manifest
compare_files

# Output
if [[ "${OPT_VERBOSE}" -eq 1 ]]; then
    print_verbose
fi
if [[ "${OPT_DIFF}" -eq 1 ]]; then
    print_diffs
fi

has_issues=$(( ${#_ic_missing[@]} + ${#_ic_mismatch[@]} + ${#_ic_unexpected[@]} ))

if [[ "${OPT_VERBOSE}" -eq 0 && "${OPT_DIFF}" -eq 0 ]]; then
    print_exceptions || true
fi

if [[ "${has_issues}" -eq 0 ]]; then
    exit 0
fi
exit 1
