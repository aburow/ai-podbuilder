#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/common.sh
source "${SCRIPT_DIR}/../lib/common.sh"
# shellcheck source=../lib/profile.sh
source "${SCRIPT_DIR}/../lib/profile.sh"

usage() {
    cat >&2 <<'EOF'
Usage: ai-build <profile>

Build (or rebuild) the container image defined by the named profile.
The image is built from IMAGE_DIR using BUILD_ARGS. If POST_BUILD_CHECK
is defined in the profile, it is run inside the freshly built image to
print installed tool/library versions.

ai-build never touches existing containers (R3.5).

Options:
  -h, --help    Show this help and exit.
EOF
}

[[ $# -eq 0 || "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage; exit 0; }

resolve_base_dir
require_cmd podman

PROFILE_NAME_ARG="$1"
load_profile "$PROFILE_NAME_ARG"

[[ -d "$IMAGE_DIR" ]] \
    || _die "IMAGE_DIR does not exist: ${IMAGE_DIR}"

_info "Building image '${IMAGE_NAME}' from ${IMAGE_DIR} …"

# shellcheck disable=SC2086
podman build $BUILD_ARGS -t "$IMAGE_NAME" "$IMAGE_DIR"

_info "Build complete: ${IMAGE_NAME}"

if [[ -n "${POST_BUILD_CHECK:-}" ]]; then
    _info "Running post-build check …"
    podman run --rm "$IMAGE_NAME" bash -c "$POST_BUILD_CHECK"
else
    _info "No POST_BUILD_CHECK defined; skipping version check."
fi
