# UxPlay AirPlay server build sandbox profile — legacy-compatibility example.
# The canonical profile location is projects/<name>/profile.env.
# profiles/ is an optional area; ai-new and normal flows never write here.
# Copy to projects/uxplay/profile.env (or profiles/uxplay.env) and adjust paths.

PROFILE_NAME="uxplay"
CONTAINER_NAME="codex-uxplay"
IMAGE_NAME="codex-uxplay-image"
IMAGE_DIR="${AI_PODMAN_JAILS_DIR}/uxplay-image"
WORKSPACE="${AI_PODMAN_JAILS_DIR}/uxplay-workspace"
CONTAINER_HOME="/home/builder"
BASHRC="${WORKSPACE}/.bashrc"
WORKDIR="/workspace"
BUILD_ARGS=""

# Optional: expose the Avahi/D-Bus socket for mDNS advertisement.
EXTRA_DEVICES=("--device=/dev/dri/renderD128")

# Optional: pass through environment for build caching.
EXTRA_ENV=("-e" "CCACHE_DIR=/workspace/.ccache")

# Optional: builder-mode cache volume for CMake artifacts.
EXTRA_VOLUMES=("-v" "${AI_PODMAN_JAILS_DIR}/uxplay-cache:/cache:Z")

# Optional: verify cmake and the UxPlay binary after build.
POST_BUILD_CHECK="cmake --version && uxplay -v 2>&1 | head -1"
