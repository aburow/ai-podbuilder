# ESP32 firmware development sandbox profile — legacy-compatibility example.
# The canonical profile location is projects/<name>/profile.env.
# profiles/ is an optional area; ai-new and normal flows never write here.
# Copy to projects/esp32/profile.env (or profiles/esp32.env) and adjust paths.

PROFILE_NAME="esp32"
CONTAINER_NAME="codex-esp32"
IMAGE_NAME="codex-esp32-image"
IMAGE_DIR="${AI_PODMAN_JAILS_DIR}/esp32-image"
WORKSPACE="${AI_PODMAN_JAILS_DIR}/esp32-workspace"
CONTAINER_HOME="/home/builder"
BASHRC="${WORKSPACE}/.bashrc"
WORKDIR="/workspace"
BUILD_ARGS="--no-cache"

# Optional: pass through USB serial device for flashing.
EXTRA_DEVICES=("--device=/dev/ttyUSB0")

# Optional: resolve the local IDF registry mirror.
EXTRA_HOSTS=("idf-mirror.local:192.168.1.10")

# Optional: propagate IDF version and toolchain path.
EXTRA_ENV=("-e" "IDF_VERSION=5.2" "-e" "IDF_TOOLS_PATH=/home/builder/.espressif")

# Optional: run after build to verify installed toolchain versions.
POST_BUILD_CHECK="xtensa-esp32-elf-gcc --version && idf.py --version"
