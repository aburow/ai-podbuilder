# profile.env — {{PROJECT_NAME}}
# Sourced by ai-launch / ai-build.  Paths derive from $HOME and $CODEX_JAILS_DIR.
# Never hardcode usernames or /var/home/ paths here.

PROJECT_NAME={{PROJECT_NAME}}
PROJECT_SLUG={{PROJECT_SLUG}}
IMAGE_NAME=localhost/{{PROJECT_SLUG}}:latest
CONTAINER_HOME=/home/user

# Workspace: host path → container path.
WORKSPACE_HOST=${CODEX_JAILS_DIR}/projects/{{PROJECT_NAME}}/workspace
WORKSPACE_CONTAINER=/workspace

# Container name used by ai-launch.
CONTAINER_NAME={{PROJECT_SLUG}}

# Network mode: host | bridge | none  (default: bridge)
NETWORK_MODE=bridge

# Additional podman run flags (space-separated; evaluated as array by ai-launch).
# Example: EXTRA_ARGS="--device /dev/dri --env DISPLAY=$DISPLAY"
EXTRA_ARGS=

# Post-build check run inside the freshly built image (optional).
# POST_BUILD_CHECK="python3 --version && pip3 --version"
POST_BUILD_CHECK=
