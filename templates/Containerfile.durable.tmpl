# Containerfile — {{PROJECT_NAME}}
# Generated by ai-new bootstrap agent.
# Build: podman build -f image/Containerfile -t {{IMAGE_TAG}} image/
#
# Replace all {{PLACEHOLDER}} values before building.

FROM {{BASE_IMAGE}}
LABEL ai-agent-podman-sandbox.project={{PROJECT_SLUG}}

# ── System packages ────────────────────────────────────────────────────────────
RUN {{PACKAGE_MANAGER}} install -y \
        {{OS_PACKAGES}} \
    && {{PACKAGE_MANAGER}} clean all

# ── Language runtime ───────────────────────────────────────────────────────────
# Add language-specific install steps here (e.g. Node.js, Python venv, Rust).
# {{LANGUAGE_RUNTIME_INSTALL}}

# ── Developer tools ────────────────────────────────────────────────────────────
# {{DEVELOPER_TOOLS_INSTALL}}

# ── Project user ──────────────────────────────────────────────────────────────
# Use a non-root user when possible; rootless Podman maps the host UID via
# --userns=keep-id so this user does not need to match the host user exactly.
ARG USERNAME=user
ARG USER_UID=1000
ARG USER_GID=${USER_UID}
RUN groupadd --gid "${USER_GID}" "${USERNAME}" \
    && useradd --uid "${USER_UID}" --gid "${USER_GID}" --shell /bin/bash \
               --create-home "${USERNAME}"
USER ${USERNAME}

# ── Framework shell defaults ──────────────────────────────────────────────────
# bashrc.default is provided by the ai-podbuilder framework and seeded into
# image/ at scaffold time.  It supplies aliases, PS1, and ~/.bashrc.d/ loading.
RUN mkdir -p /etc/ai-podbuilder
COPY bashrc.default /etc/ai-podbuilder/bashrc

# ── Working directory ──────────────────────────────────────────────────────────
WORKDIR {{CONTAINER_WORKDIR}}

# ── Exposed ports ─────────────────────────────────────────────────────────────
# {{EXPOSE_PORTS}}

# ── Default entrypoint ────────────────────────────────────────────────────────
CMD ["/bin/bash"]
